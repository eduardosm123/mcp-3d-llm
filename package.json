{
  "name": "canvas3d-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server that gives AI agents eyes and instruments for building 3D scenes in HTML canvas: multi-angle screenshots, structured scene validation, and helper libraries.",
  "type": "module",
  "scripts": {
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
